{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://i3s.unice.fr/activity-tracker/schema/session.schema.json",
  "title": "WebGaze Activity Tracker — Session Log",
  "description": "Format structuré d'export d'une session de suivi du regard (PIR Activity Tracker). Produit par GazeLogger.export().",
  "type": "object",
  "required": ["session", "raw_gaze_data", "events", "aoi_hits", "interactions"],
  "additionalProperties": false,
  "properties": {
    "session": { "$ref": "#/definitions/session" },
    "raw_gaze_data": {
      "type": "array",
      "description": "Points de regard bruts (après correction et lissage), un par frame.",
      "items": { "$ref": "#/definitions/gazePoint" }
    },
    "events": {
      "type": "array",
      "description": "Événements de haut niveau extraits par post-traitement (fixations, saccades).",
      "items": { "$ref": "#/definitions/event" }
    },
    "aoi_hits": {
      "type": "array",
      "description": "Fixations tombant dans une zone d'intérêt (Area Of Interest).",
      "items": { "$ref": "#/definitions/aoiHit" }
    },
    "interactions": {
      "type": "array",
      "description": "Journal d'interactions multimodales (clics, survols regard, navigation, contrôles).",
      "items": { "$ref": "#/definitions/interaction" }
    },
    "viz_states": {
      "type": "array",
      "description": "Historique des états de la visualisation (vue active, dataset, zoom, sélection, filtres).",
      "items": { "$ref": "#/definitions/vizStateEntry" }
    }
  },
  "definitions": {
    "session": {
      "type": "object",
      "required": ["id", "participant_id", "start_time"],
      "properties": {
        "id":             { "type": "string", "description": "UUID v4 de la session." },
        "format_version": { "type": "string", "description": "Version du format d'export (semver)." },
        "participant_id": { "type": "string" },
        "start_time":     { "type": "string", "format": "date-time" },
        "end_time":       { "type": ["string", "null"], "format": "date-time" },
        "clock_origin_ms": {
          "type": "number",
          "description": "Origine de l'horloge monotone (performance.now()). Les t_rel_ms y sont relatifs."
        },
        "screen_resolution": {
          "type": "object",
          "properties": {
            "width":  { "type": "number" },
            "height": { "type": "number" }
          }
        },
        "device_pixel_ratio": { "type": "number" },
        "user_agent": { "type": ["string", "null"] },
        "browser":    { "type": "string" },
        "calibration_score": {
          "type": ["object", "null"],
          "description": "Qualité de calibration au démarrage de la session.",
          "properties": {
            "mean_error_px": { "type": ["number", "null"] },
            "std_error_px":  { "type": ["number", "null"] }
          }
        },
        "calibration_version": { "type": ["string", "null"] },
        "config_snapshot": {
          "type": ["object", "null"],
          "description": "Instantané des paramètres de filtrage/correction (reproductibilité)."
        }
      }
    },
    "gazePoint": {
      "type": "object",
      "required": ["x", "y", "timestamp"],
      "properties": {
        "x":         { "type": "number", "description": "Coordonnée écran X corrigée (px)." },
        "y":         { "type": "number", "description": "Coordonnée écran Y corrigée (px)." },
        "raw_x":     { "type": "number", "description": "Coordonnée X brute (avant correction)." },
        "raw_y":     { "type": "number", "description": "Coordonnée Y brute (avant correction)." },
        "timestamp": { "type": "number", "description": "Epoch ms (Date.now())." },
        "t_rel_ms":  { "type": "number", "description": "Temps relatif à clock_origin_ms (horloge monotone)." },
        "confidence":{ "type": "number", "description": "Confiance de la prédiction ∈ [0,1]." },
        "source_module": { "type": "string", "description": "Moteur émetteur : 'webgazer' | 'mediapipe'." },
        "dom":       { "$ref": "#/definitions/domDescriptor" },
        "viz_state": { "$ref": "#/definitions/vizState" }
      }
    },
    "domDescriptor": {
      "type": "object",
      "description": "Descripteur détaillé de l'objet DOM observé (barre, axe, point, légende…).",
      "properties": {
        "tag":           { "type": "string" },
        "id":            { "type": ["string", "null"] },
        "classes":       { "type": "array", "items": { "type": "string" } },
        "semantic_type": { "type": "string", "description": "bar | axis | legend | point | line | label | …" },
        "bbox":          {
          "type": "object",
          "properties": {
            "x": { "type": "number" }, "y": { "type": "number" },
            "width": { "type": "number" }, "height": { "type": "number" }
          }
        },
        "text":         { "type": ["string", "null"] },
        "aria_label":   { "type": ["string", "null"] },
        "data":         { "type": ["object", "null"], "description": "Attributs data-* de l'élément." },
        "css_selector": { "type": ["string", "null"] }
      }
    },
    "vizState": {
      "type": "object",
      "description": "État de la visualisation au moment du regard.",
      "properties": {
        "active_view": { "type": "string", "description": "bar | line | scatter." },
        "dataset":     { "type": "string" },
        "gaze_mode":   { "type": "boolean" },
        "current_aoi": { "type": ["string", "null"] },
        "selection":   { "type": ["string", "null"] },
        "zoom":        { "type": "number" },
        "filters":     { "type": "array" },
        "n_aois":      { "type": "number" },
        "viewport":    { "type": "object" }
      }
    },
    "vizStateEntry": {
      "type": "object",
      "required": ["state", "timestamp"],
      "properties": {
        "state":     { "$ref": "#/definitions/vizState" },
        "timestamp": { "type": "number" },
        "t_rel_ms":  { "type": "number" }
      }
    },
    "event": {
      "type": "object",
      "required": ["type", "start_time", "end_time", "duration"],
      "properties": {
        "type":       { "type": "string", "enum": ["fixation", "saccade", "unknown"] },
        "start_time": { "type": "number" },
        "end_time":   { "type": "number" },
        "duration":   { "type": "number" },
        "details": {
          "type": "object",
          "description": "Charge utile selon le type : {x,y,points_count} pour une fixation, {start_x,start_y,end_x,end_y,amplitude,peak_velocity} pour une saccade.",
          "additionalProperties": true
        },
        "source_module": { "type": "string" }
      }
    },
    "aoiHit": {
      "type": "object",
      "required": ["aoi_id", "aoi_label", "event_index"],
      "properties": {
        "aoi_id":      { "type": "string" },
        "aoi_label":   { "type": "string" },
        "event_index": { "type": "number", "description": "Index dans le tableau events[] de la fixation associée." },
        "timestamp":   { "type": "number" },
        "t_rel_ms":    { "type": "number" },
        "source_module": { "type": "string" },
        "dom":         { "$ref": "#/definitions/domDescriptor" },
        "viz_state":   { "$ref": "#/definitions/vizState" }
      }
    },
    "interaction": {
      "type": "object",
      "required": ["type", "timestamp"],
      "properties": {
        "type": {
          "type": "string",
          "description": "Type d'interaction.",
          "examples": ["session_start", "session_stop", "tab_change", "gaze_enter_aoi", "export", "control", "online_recalibration"]
        },
        "details":       { "type": "object", "additionalProperties": true },
        "source_module": { "type": "string" },
        "timestamp":     { "type": "number" },
        "t_rel_ms":      { "type": "number" }
      }
    }
  }
}
